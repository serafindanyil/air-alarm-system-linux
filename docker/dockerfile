FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    wget \
    curl \
    rsync \
    bc \
    bison \
    flex \
    cpio \
    unzip \
    file \
    python3 \
    perl \
    libncurses-dev \
    && rm -rf /var/lib/apt/lists/*